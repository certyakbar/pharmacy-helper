# Copy to .env for local development. Values are provided by Lovable Cloud.
# Do NOT commit real values.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# HMAC pepper (>=16 chars) used to key handover code hashes.
# Read on the TanStack server ONLY (never sent to the browser, never stored
# in the database, never set as a session GUC). The server computes
# HMAC-SHA-256(normalised_code, HANDOVER_CODE_PEPPER) and passes the hex
# digest to public.staff_open_handover_by_hash.
HANDOVER_CODE_PEPPER=

# Pilot-stage kiosk store identity. Server-only: consumed by the finder
# server functions (getFinderBootstrap / searchProducts / getProductDetail)
# to resolve the authoritative store for this device. Never accepted from
# the browser. Will be replaced by the kiosk_devices registration flow
# post-pilot.
KIOSK_STORE_ID=
