# HMAC pepper (>=16 chars) used to key handover code hashes.
# Set as a session GUC before invoking public.staff_open_handover:
#   SELECT set_config('app.settings.handover_pepper', $1, true);
# Never store this in the database or return it to the client.
HANDOVER_CODE_PEPPER=
